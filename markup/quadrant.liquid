{% comment %}
  QUADRANT (400x240): the "Final Four" only — both semi-finals meeting at the
  Final. Columns: SF | FINAL | SF. Largest type, fully legible at a glance.
{% endcomment %}
<div class="layout layout--col">
<div class="wm-ko ko-canvas d-quad">

  <div class="ko-head">
    <span class="ttl">⚽ WM 2026 · Halbfinals</span>
    {% if champion %}<span class="meta">★ {{ champion.code }}</span>{% endif %}
  </div>

  <div class="ko-bracket">
    <div class="ko-side ko-left">
      <div class="ko-round">{% for m in left.sf %}<div class="ko-match"><div class="mbox"><div class="mrow{% if m.t1.winner %} win{% elsif m.t1.loser %} lose{% endif %}{% unless m.t1.resolved %} tbd{% endunless %}"><span class="cd">{{ m.t1.code }}</span>{% if m.t1.score != nil %}<span class="sc">{{ m.t1.score }}</span>{% endif %}</div><div class="mrow{% if m.t2.winner %} win{% elsif m.t2.loser %} lose{% endif %}{% unless m.t2.resolved %} tbd{% endunless %}"><span class="cd">{{ m.t2.code }}</span>{% if m.t2.score != nil %}<span class="sc">{{ m.t2.score }}</span>{% endif %}</div>{% if m.note %}<span class="note">{{ m.note }}</span>{% endif %}</div></div>{% endfor %}</div>
    </div>

    <div class="ko-center">
      {% if final %}<div class="ko-final"><div class="fhd">FINALE</div><div class="mrow{% if final.t1.winner %} win{% elsif final.t1.loser %} lose{% endif %}{% unless final.t1.resolved %} tbd{% endunless %}"><span class="cd">{{ final.t1.code }}</span>{% if final.t1.score != nil %}<span class="sc">{{ final.t1.score }}</span>{% endif %}</div><div class="mrow{% if final.t2.winner %} win{% elsif final.t2.loser %} lose{% endif %}{% unless final.t2.resolved %} tbd{% endunless %}"><span class="cd">{{ final.t2.code }}</span>{% if final.t2.score != nil %}<span class="sc">{{ final.t2.score }}</span>{% endif %}</div>{% if final.note %}<span class="note">{{ final.note }}</span>{% endif %}</div>{% endif %}
    </div>

    <div class="ko-side ko-right">
      <div class="ko-round">{% for m in right.sf %}<div class="ko-match"><div class="mbox"><div class="mrow{% if m.t1.winner %} win{% elsif m.t1.loser %} lose{% endif %}{% unless m.t1.resolved %} tbd{% endunless %}"><span class="cd">{{ m.t1.code }}</span>{% if m.t1.score != nil %}<span class="sc">{{ m.t1.score }}</span>{% endif %}</div><div class="mrow{% if m.t2.winner %} win{% elsif m.t2.loser %} lose{% endif %}{% unless m.t2.resolved %} tbd{% endunless %}"><span class="cd">{{ m.t2.code }}</span>{% if m.t2.score != nil %}<span class="sc">{{ m.t2.score }}</span>{% endif %}</div>{% if m.note %}<span class="note">{{ m.note }}</span>{% endif %}</div></div>{% endfor %}</div>
    </div>
  </div>
</div>
</div>
